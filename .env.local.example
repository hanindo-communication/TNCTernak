# Copy to .env.local — never commit .env.local
# Project: https://supabase.com/dashboard/project/dnphxqaqlyniobnlicfx

NEXT_PUBLIC_SUPABASE_URL=https://dnphxqaqlyniobnlicfx.supabase.co

# Use the Publishable key from Supabase (Settings → API) — may start with sb_publishable_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key

# Optional: Secret key (sb_secret_...) — server-only, never prefix dengan NEXT_PUBLIC_
# SUPABASE_SECRET_KEY=your_secret_key

# Untuk npm run db:apply-segment (migrasi SQL dari mesin lokal):
# Supabase → Project Settings → Database → Connection string → URI
# DATABASE_URL=postgresql://postgres.[REF]:[YOUR-DB-PASSWORD]@db.[REF].supabase.co:5432/postgres

# Optional: Personal Access Token (Dashboard → Account → Access Tokens) untuk script Management API
# saja — jangan pakai di client. Scope: auth_config_write (+ project_admin_write).
# Dipakai oleh scripts/set-supabase-mailer-autoconfirm.ps1
# SUPABASE_ACCESS_TOKEN=
